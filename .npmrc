; Phase 03 Plan 01 — required for @anthropic-ai/sdk@0.95.x to coexist with
; @copilotkit/runtime@1.57.1, which declares a peerOptional dependency on
; @anthropic-ai/sdk@^0.57.0. CLAUDE.md mandates 0.95.x; the CopilotKit
; AnthropicAdapter integration is not used by this project (Phase 1 used
; BuiltInAgent and Phase 3+ uses the @anthropic-ai/sdk client directly).
;
; Without this flag, `npx shadcn@latest init/add` and other tools that
; invoke `npm install` internally fail with ERESOLVE.
legacy-peer-deps=true
