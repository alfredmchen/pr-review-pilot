# .env.local.example — commit this file (no real values).
# Copy to .env.local and fill in real values. .env.local is gitignored.

# GitHub Personal Access Token — classic PAT with `public_repo` scope.
# NEVER prefix with NEXT_PUBLIC_ — this would bake the token into the JS bundle
# at build time and expose it to every visitor of the deployed site.
GITHUB_TOKEN=

# Anthropic API Key.
# NEVER prefix with NEXT_PUBLIC_ — same exposure risk as above.
# In Phase 1 a placeholder value (e.g. sk-ant-placeholder) is sufficient
# for the route handler to register; real key is only needed when CopilotKit
# actually calls Claude.
ANTHROPIC_API_KEY=
